# Copy this file to .env and fill in your values.

# Required: your bot token from the Discord Developer Portal.
DISCORD_TOKEN=your-bot-token-here

# Folder to scan for audio files (relative to the project, or an absolute path).
MUSIC_DIR=music

# Optional: one or more server (guild) IDs, comma-separated. When set, slash
# commands sync to each listed guild instantly — handy during development.
# Leave blank for global sync (first propagation can take up to an hour).
# Examples:  GUILD_ID=123456789012345678
#            GUILD_ID=123456789012345678,987654321098765432
GUILD_ID=

# Optional: seconds of inactivity before the bot auto-disconnects (default 300).
IDLE_TIMEOUT=300
